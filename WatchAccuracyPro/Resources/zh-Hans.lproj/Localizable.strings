"glossary.snr" = "SNR(信噪比)";
"glossary.snr.desc" = "腕表声音相对环境噪声的比值(dB)。越高越好 — 至少需要 12 dB 才能获得可靠结果。";
"glossary.drift" = "漂移";
"glossary.drift.desc" = "因温度、表位或发条松紧导致走时随时间发生变化的倾向。";
"glossary.isochronism" = "等时性";
"glossary.isochronism.desc" = "机芯无论动力储存剩余多少,均能保持稳定走时的能力。等时性越好,精度越稳定。";
"glossary.positional" = "方位差";
"glossary.positional.desc" = "走时随腕表朝向(表盘朝上/朝下、表冠各方向)而变化的程度。可通过六方位测试检验。";
"glossary.power_reserve" = "动力储存 (Power Reserve)";
"glossary.power_reserve.desc" = "上满弦后腕表可持续运行的时间。通常 38–80 小时。动力不足时振幅下降,走时可能跌至 −20s/d 以下。";
"glossary.overhaul" = "大保养 (Overhaul)";
"glossary.overhaul.desc" = "拆解、清洗、加油、重组机芯的全套保养。通常建议每 4–6 年进行一次。";
"glossary.magnetism" = "磁化 (Magnetism)";
"glossary.magnetism.desc" = "靠近吹风机、扬声器或 MagSafe 配件会使游丝磁化,导致走时异常变快。需用消磁器消磁。";
"glossary.escapement" = "擒纵机构 (Escapement)";
"glossary.escapement.desc" = "以固定节奏释放主发条能量的核心部件。瑞士杠杆式(最常见)、同轴式 (Omega)、Spring drive (Seiko) 等。";

