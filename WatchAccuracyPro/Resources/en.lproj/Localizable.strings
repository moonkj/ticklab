"glossary.snr.desc" = "The ratio of the watch's sound to ambient noise (dB). Higher is better — at least 12 dB is needed for a reliable result.";
"glossary.drift" = "Drift";
"glossary.drift.desc" = "The tendency of rate to change over time due to temperature, position, or mainspring tension.";
"glossary.isochronism" = "Isochronism";
"glossary.isochronism.desc" = "A movement's ability to keep consistent rate regardless of how much power reserve remains. Higher isochronism means more stable accuracy.";
"glossary.positional" = "Positional Variation";
"glossary.positional.desc" = "How much rate changes depending on the watch's orientation (dial-up, dial-down, crown positions). Checked with a 6-position test.";
"glossary.power_reserve" = "Power Reserve";
"glossary.power_reserve.desc" = "How long the watch runs after a full wind. Typically 38–80 hours. Low power drops amplitude and can push rate below −20s/d.";
"glossary.overhaul" = "Overhaul";
"glossary.overhaul.desc" = "Full service — disassembling, cleaning, re-oiling, and reassembling the movement. Usually recommended every 4–6 years.";
"glossary.magnetism" = "Magnetism";
"glossary.magnetism.desc" = "Hair dryers, speakers, and MagSafe accessories can magnetize the hairspring, making rate run abnormally fast. Demagnetize to restore.";
"glossary.escapement" = "Escapement";
